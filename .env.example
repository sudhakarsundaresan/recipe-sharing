# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

# Connection string for your Postgres database (e.g. from Render Postgres:
# dashboard -> your database -> "External Database URL").
DATABASE_URL=postgres://user:password@host:5432/dbname

# Secret used to sign session cookies. Any long random string works locally;
# generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-random-string

# Optional: override the n8n YouTube-extraction webhook URL.
# N8N_YOUTUBE_WEBHOOK_URL=https://ssudha17.app.n8n.cloud/webhook/youtube-transcript

# Optional: override the port (Render sets this automatically in production).
# PORT=4200
